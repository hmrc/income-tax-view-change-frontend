# agent specific routes


# Enter Clients UTR
GET         /client-utr                                                    hub.controllers.agent.EnterClientsUTRController.show()
POST        /client-utr                                                    hub.controllers.agent.EnterClientsUTRController.submit()
GET         /client-utr/:utr                                               hub.controllers.agent.EnterClientsUTRController.showWithUtr(utr: String)

# Confirm Client
GET         /confirm-client-details                                         hub.controllers.agent.ConfirmClientUTRController.show()
POST        /confirm-client-details                                         hub.controllers.agent.ConfirmClientUTRController.submit()

# UTR Error
GET         /cannot-view-client                                            hub.controllers.agent.UTRErrorController.show()
POST        /cannot-view-client                                            hub.controllers.agent.UTRErrorController.submit()

#Home Controller
GET         /remove-client-sessions                                        hub.controllers.agent.RemoveClientDetailsSessionsController.show()

