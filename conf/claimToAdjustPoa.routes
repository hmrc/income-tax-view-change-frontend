GET          /adjust-poa/select-your-reason                                 financials.controllers.claimToAdjustPoa.SelectYourReasonController.show(isAgent: Boolean = false, mode: Mode = NormalMode)
GET          /adjust-poa/change-your-reason                                 financials.controllers.claimToAdjustPoa.SelectYourReasonController.show(isAgent: Boolean = false, mode: Mode = CheckMode)

GET          /agents/adjust-poa/select-your-reason                          financials.controllers.claimToAdjustPoa.SelectYourReasonController.show(isAgent: Boolean = true, mode: Mode = NormalMode)
