POST         /adjust-poa/enter-poa-amount                                   financials.controllers.claimToAdjustPoa.EnterPoaAmountController.submit(isAgent: Boolean = false, mode: Mode = NormalMode)
POST         /agents/adjust-poa/enter-poa-amount                            financials.controllers.claimToAdjustPoa.EnterPoaAmountController.submit(isAgent: Boolean = true, mode: Mode = NormalMode)

POST         /adjust-poa/change-poa-amount                                   financials.controllers.claimToAdjustPoa.EnterPoaAmountController.submit(isAgent: Boolean = false, mode: Mode = CheckMode)
POST         /agents/adjust-poa/change-poa-amount                            financials.controllers.claimToAdjustPoa.EnterPoaAmountController.submit(isAgent: Boolean = true, mode: Mode = CheckMode)

GET          /adjust-poa/check-your-answers                                 financials.controllers.claimToAdjustPoa.CheckYourAnswersController.show(isAgent: Boolean = false)
GET          /agents/adjust-poa/check-your-answers                          financials.controllers.claimToAdjustPoa.CheckYourAnswersController.show(isAgent: Boolean = true)

POST          /adjust-poa/check-your-answers                                 financials.controllers.claimToAdjustPoa.CheckYourAnswersController.submit(isAgent: Boolean = false)
POST          /agents/adjust-poa/check-your-answers                          financials.controllers.claimToAdjustPoa.CheckYourAnswersController.submit(isAgent: Boolean = true)

GET          /adjust-poa/confirmation                                       financials.controllers.claimToAdjustPoa.ConfirmationForAdjustingPoaController.show(isAgent: Boolean = false)
GET          /agents/adjust-poa/confirmation                                financials.controllers.claimToAdjustPoa.ConfirmationForAdjustingPoaController.show(isAgent: Boolean = true)

