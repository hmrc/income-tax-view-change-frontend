POST         /agents/adjust-poa/change-your-reason                          financials.controllers.claimToAdjustPoa.SelectYourReasonController.submit(isAgent: Boolean = true, mode: Mode = CheckMode)

GET          /adjust-poa/enter-poa-amount                                   financials.controllers.claimToAdjustPoa.EnterPoaAmountController.show(isAgent: Boolean = false, mode: Mode = NormalMode)
